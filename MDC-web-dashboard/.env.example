# Environment variable reference for all deployment targets.
# Copy this file and fill in values for your environment.
# These vars are read at RUNTIME — the Docker image is environment-agnostic.
#
# For Azure App Service: set these in Configuration > Application Settings
# For Azure Container Apps: set these in Containers > Environment Variables
# For local dev: copy to .env.local and fill in values

# MicroDataCluster API
MDC_API_URL=https://microdatacluster.com
BRIDGE_API_URL=https://microdatacluster.com
API_URL=https://microdatacluster.com

# Microsoft Entra ID (CIAM) — from Azure Portal > Entra ID > App Registrations
ENTRA_CLIENT_ID=
ENTRA_TENANT_ID=
ENTRA_REDIRECT_URI=https://your-app-url.example.com
ENTRA_AUTHORITY=https://tensparrowsmicrodatacluster.ciamlogin.com/<TENANT_ID>
MDC_SCOPE=api://<CLIENT_ID>/MDC.Access

# Optional: dev API key fallback (leave empty in production)
MDC_DEV_API_KEY=

# Admin Console URL
ADMIN_APP_URL=
