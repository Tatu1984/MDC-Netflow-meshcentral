# Admin Console - Environment Configuration Template
# Copy this file to .env.local for local development

# MicroDataCluster C# Backend API URL
NEXT_PUBLIC_MDC_API_URL=https://www.microdatacluster.com

# Microsoft Entra ID (CIAM) Configuration
# Create an App Registration in Azure AD for the admin dashboard
# Reference: https://learn.microsoft.com/en-us/entra/external-id/customers/

# Your Admin App Registration Client ID
NEXT_PUBLIC_ENTRA_CLIENT_ID=your-admin-client-id-here

# Your Entra Tenant ID
NEXT_PUBLIC_ENTRA_TENANT_ID=88714d9d-6787-42a3-929c-4242bac15119

# Redirect URI (must match App Registration configuration)
NEXT_PUBLIC_ENTRA_REDIRECT_URI=http://localhost:3001/auth/callback

# Entra Authority URL (for CIAM tenants)
NEXT_PUBLIC_ENTRA_AUTHORITY=https://tensparrowsmicrodatacluster.ciamlogin.com/88714d9d-6787-42a3-929c-4242bac15119/v2.0

# API Scope (format: api://{clientId}/scope-name)
NEXT_PUBLIC_MDC_SCOPE=api://your-admin-client-id-here/MDC.Access
